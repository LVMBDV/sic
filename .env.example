# Server
SIC_BIND=0.0.0.0:6767
SIC_PUBLIC_URL=https://comments.example.com

# Database (file path; `:memory:` for tests)
DATABASE_URL=sic.db

# Session signing key (32+ random bytes/chars)
# Generate: openssl rand -base64 32
SIC_SESSION_SECRET=changeme-please-use-a-real-secret

# Allowed origins for the embed (comma-separated). Used for CSP frame-ancestors and CORS.
SIC_ALLOWED_ORIGINS=https://blog.example.com,https://www.example.com

# OAuth: GitHub
SIC_GITHUB_CLIENT_ID=
SIC_GITHUB_CLIENT_SECRET=

# OAuth: Google
SIC_GOOGLE_CLIENT_ID=
SIC_GOOGLE_CLIENT_SECRET=

# Logging (fastify pino levels: trace|debug|info|warn|error)
LOG_LEVEL=info
